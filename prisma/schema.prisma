generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Role {
  id         String @id @default(uuid())
  nome       String @unique // reporter, editor, juridico, admin
  permissoes Json?
  users      User[]
}

model User {
  id            String   @id @default(uuid())
  nome          String
  email         String   @unique
  senha_hash    String
  cargo_id      String
  bio           String?
  redes_sociais Json?
  mfa_secret    String?
  status        String   @default("ativo")
  created_at    DateTime @default(now())

  cargo             Role      @relation(fields: [cargo_id], references: [id])
  articles_authored Article[] @relation("ArticleAuthor")
  articles_edited   Article[] @relation("ArticleEditor")
  articles_revised  Article[] @relation("ArticleRevisor")
}

model Article {
  id              String    @id @default(uuid())
  titulo          String
  slug            String    @unique
  corpo_texto     String
  resumo          String?
  autor_id        String
  editor_id       String?
  revisor_id      String?
  categoria_id    String?
  status_id       String    @default("rascunho")
  data_publicacao DateTime?
  visualizacoes   Int       @default(0)
  og_image_url    String?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  autor     User      @relation("ArticleAuthor", fields: [autor_id], references: [id])
  editor    User?     @relation("ArticleEditor", fields: [editor_id], references: [id])
  revisor   User?     @relation("ArticleRevisor", fields: [revisor_id], references: [id])
  categoria Category? @relation(fields: [categoria_id], references: [id])
}

model Category {
  id               String  @id @default(uuid())
  nome             String
  slug             String  @unique
  esfera           String?
  cor              String?
  meta_description String?
  parent_id        String?

  parent   Category?  @relation("SubCategories", fields: [parent_id], references: [id])
  children Category[] @relation("SubCategories")
  articles Article[]
}
