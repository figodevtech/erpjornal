generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Role {
  id         String @id @default(uuid())
  nome       String @unique // reporter, editor, juridico, admin
  permissoes Json?
  users      User[]
}

model User {
  id            String   @id @default(uuid())
  nome          String
  email         String   @unique
  senha_hash    String
  cargo_id      String
  bio           String?
  redes_sociais Json?
  mfa_secret    String?
  status        String   @default("ativo")
  created_at    DateTime @default(now())

  cargo             Role        @relation(fields: [cargo_id], references: [id])
  articles_authored Article[]   @relation("ArticleAuthor")
  articles_edited   Article[]   @relation("ArticleEditor")
  articles_revised  Article[]   @relation("ArticleRevisor")
  action_logs       ActionLog[]
  fontes_criadas    Source[]    @relation("SourceCreator")
  notas_fonte       SourceNote[] @relation("SourceNoteAuthor")
}

model Article {
  id              String    @id @default(uuid())
  titulo          String
  slug            String    @unique
  corpo_texto     String
  resumo          String?
  autor_id        String
  editor_id       String?
  revisor_id      String?
  categoria_id    String?
  status_id       String    @default("rascunho")
  legal_notes     String?
  legal_status    String    @default("pendente") // pendente, em_analise, aprovado, ajustes
  data_publicacao DateTime?
  regiao          String?   // Nacional, Estadual, Municipal
  estado          String?   // SIGLA (DF, SP, etc)
  visualizacoes   Int       @default(0)
  og_image_url    String?
  is_premium      Boolean   @default(false)
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  autor       User        @relation("ArticleAuthor", fields: [autor_id], references: [id])
  editor      User?       @relation("ArticleEditor", fields: [editor_id], references: [id])
  revisor     User?       @relation("ArticleRevisor", fields: [revisor_id], references: [id])
  categoria   Category?        @relation(fields: [categoria_id], references: [id])
  action_logs ActionLog[]
  versions    ArticleVersion[]
  fact_checks FactCheck[]
  politicos   Politician[] @relation("ArticlePoliticians")
  fonte_notas SourceNote[]
}

model Politician {
  id           String    @id @default(uuid())
  nome         String
  cargo        String?
  partido      String?
  biografia    String?
  foto_url     String?
  regiao       String?   // Nacional, Estadual, Municipal
  estado       String?   // SIGLA (DF, SP, etc)
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt
  artigos      Article[] @relation("ArticlePoliticians")
}

model FactCheck {
  id                String   @id @default(uuid())
  article_id        String
  article           Article  @relation(fields: [article_id], references: [id])
  fonte_url         String?
  documento_url     String?
  status_verificacao String   @default("verificado") // verificado, suspeito, falso
  created_at        DateTime @default(now())
}

model ArticleVersion {
  id              String   @id @default(uuid())
  article_id      String
  article         Article  @relation(fields: [article_id], references: [id])
  titulo          String
  resumo          String?
  corpo_texto     String
  status_id       String
  user_id         String?
  mudancas_resumo String?
  created_at      DateTime @default(now())
}

model Category {
  id               String  @id @default(uuid())
  nome             String
  slug             String  @unique
  esfera           String?
  cor              String?
  meta_description String?
  parent_id        String?

  parent   Category?  @relation("SubCategories", fields: [parent_id], references: [id])
  children Category[] @relation("SubCategories")
  articles Article[]
}

model ActionLog {
  id         String   @id @default(uuid())
  user_id    String
  user       User     @relation(fields: [user_id], references: [id])
  acao       String
  article_id String?
  article    Article? @relation(fields: [article_id], references: [id])
  data_hora  DateTime @default(now())
}

model Media {
  id                String   @id @default(uuid())
  url               String
  nome              String
  tipo              String   // image, video, document
  mimetype          String?
  tamanho           Int?

  // Metadados avançados (M2-PLUS-T4-ST1)
  direitos_autorais String?
  tipo_licenca      String?  // Ex: CC BY-SA, Pago, Livre
  fonte             String?
  data_expiracao    DateTime?

  // IA Tags (M2-PLUS-T4-ST2)
  tags_ia           Json?    // Array de tags sugeridas por IA

  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt
}

model Source {
  id            String   @id @default(uuid())
  nome          String
  cargo         String?
  organizacao   String?
  email         String?
  telefone      String?
  nivel_sigilo  String   @default("publico") // publico, reservado, confidencial
  notas         String?
  criador_id    String
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  criador     User         @relation("SourceCreator", fields: [criador_id], references: [id])
  anotacoes   SourceNote[]
}

model SourceNote {
  id         String   @id @default(uuid())
  source_id  String
  autor_id   String
  conteudo   String
  article_id String?
  created_at DateTime @default(now())

  source  Source   @relation(fields: [source_id], references: [id], onDelete: Cascade)
  autor   User     @relation("SourceNoteAuthor", fields: [autor_id], references: [id])
  article Article? @relation(fields: [article_id], references: [id])
}

model PodcastEpisode {
  id          String   @id @default(uuid())
  titulo      String
  slug        String   @unique
  descricao   String?  @db.Text
  audio_url   String
  capa_url    String?
  duracao     Int?     // segundos
  data_pub    DateTime @default(now())
  tags        String[]
  status      String   @default("draft") // draft, published
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
}
